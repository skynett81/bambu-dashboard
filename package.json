{
  "name": "bambu-dashboard",
  "version": "1.1.13",
  "type": "module",
  "description": "Self-hosted dashboard for Bambu Lab 3D printers",
  "author": "SkyNett81",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/skynett81/bambu-dashboard.git"
  },
  "homepage": "https://github.com/skynett81/bambu-dashboard",
  "bugs": {
    "url": "https://github.com/skynett81/bambu-dashboard/issues"
  },
  "keywords": [
    "bambu-lab",
    "3d-printer",
    "dashboard",
    "mqtt",
    "self-hosted"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "demo": "BAMBU_DEMO=true node --watch server/index.js",
    "setup": "node server/setup-wizard.js",
    "test": "node --test --test-force-exit tests/**/*.test.js",
    "postinstall": "cd website && npm install --silent 2>/dev/null && npm run build 2>/dev/null || true",
    "docs:dev": "cd website && npm start",
    "docs:build": "cd website && npm run build",
    "docs:serve": "cd website && npm run serve"
  },
  "dependencies": {
    "admin-lte": "^4.0.0-rc7",
    "basic-ftp": "^5.2.0",
    "mqtt": "^5.10.0",
    "ws": "^8.18.0"
  }
}
